/* 登录页面样式 */

.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx;
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

/* 头部区域 */
.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 80rpx;
}

.logo {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 30rpx;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 登录按钮区域 */
.login-section {
  width: 100%;
  margin-bottom: 40rpx;
}

.login-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #ffffff !important;
  color: #667eea !important;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 50rpx;
  padding: 28rpx 0;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
}

.login-btn[disabled] {
  opacity: 0.7;
}

.wechat-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 16rpx;
}

/* 协议区域 */
.policy-section {
  width: 100%;
  margin-bottom: 60rpx;
}

.policy-check {
  display: flex;
  align-items: flex-start;
}

.policy-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  line-height: 1.6;
  margin-left: 12rpx;
}

.policy-link {
  color: #ffffff;
  text-decoration: underline;
}

/* 功能介绍 */
.features {
  width: 100%;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 30rpx;
}

.feature-item {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 24rpx;
  padding: 24rpx;
  backdrop-filter: blur(10rpx);
}

.feature-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.feature-text {
  font-size: 26rpx;
  color: #ffffff;
}
