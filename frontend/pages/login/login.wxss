/* pages/login/login.wxss */
.login-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #1890ff 0%, #096dd9 100%);
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 60rpx 40rpx;
}

.login-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

/* Logo 区域 */
.logo-section {
  text-align: center;
  margin-bottom: 120rpx;
}

.logo-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.app-name {
  font-size: 48rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 15rpx;
}

.app-slogan {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 登录按钮 */
.login-actions {
  margin-bottom: 80rpx;
}

.login-button {
  background: #ffffff;
  color: #1890ff;
  border: none;
  border-radius: 50rpx;
  padding: 30rpx;
  font-size: 32rpx;
  font-weight: bold;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
  margin-bottom: 30rpx;
}

.login-button:active {
  transform: scale(0.98);
  background: #f0f0f0;
}

.button-content {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 15rpx;
}

.wechat-icon {
  font-size: 36rpx;
}

.login-tips {
  text-align: center;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

/* 功能特点 */
.features-section {
  display: flex;
  justify-content: space-around;
  padding: 40rpx 0;
}

.feature-item {
  text-align: center;
}

.feature-icon {
  font-size: 60rpx;
  margin-bottom: 15rpx;
}

.feature-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* 底部说明 */
.footer-text {
  text-align: center;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.6);
}

.link-text {
  color: #ffffff;
  text-decoration: underline;
}
