<!--pages/login/login.wxml-->
<view class="login-container">
  <view class="login-content">
    <!-- Logo 区域 -->
    <view class="logo-section">
      <view class="logo-icon">📚</view>
      <view class="app-name">雅思智能背单词</view>
      <view class="app-slogan">科学记忆 · 高效学习</view>
    </view>

    <!-- 登录按钮 -->
    <view class="login-actions">
      <button 
        class="login-button" 
        bindtap="handleWechatLogin"
        loading="{{loginLoading}}">
        <view class="button-content">
          <view class="wechat-icon">💬</view>
          <text>微信一键登录</text>
        </view>
      </button>
      
      <view class="login-tips">
        <text>登录后将同步您的学习进度</text>
      </view>
    </view>

    <!-- 功能特点 -->
    <view class="features-section">
      <view class="feature-item">
        <view class="feature-icon">🎯</view>
        <view class="feature-text">智能规划</view>
      </view>
      <view class="feature-item">
        <view class="feature-icon">📊</view>
        <view class="feature-text">进度追踪</view>
      </view>
      <view class="feature-item">
        <view class="feature-icon">🔊</view>
        <view class="feature-text">发音练习</view>
      </view>
    </view>
  </view>

  <!-- 底部说明 -->
  <view class="footer-text">
    <text>登录即代表您同意</text>
    <text class="link-text">《用户协议》</text>
    <text>和</text>
    <text class="link-text">《隐私政策》</text>
  </view>
</view>
