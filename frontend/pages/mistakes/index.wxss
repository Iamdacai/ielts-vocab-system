/* pages/mistakes/index.wxss */
.container {
  padding: 20rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

/* 统计卡片 */
.stats-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  color: white;
}

.stats-header {
  margin-bottom: 30rpx;
}

.stats-header .title {
  font-size: 36rpx;
  font-weight: bold;
  display: block;
}

.stats-header .subtitle {
  font-size: 24rpx;
  opacity: 0.9;
  margin-top: 10rpx;
  display: block;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
}

.stat-item {
  text-align: center;
  background: rgba(255,255,255,0.1);
  padding: 20rpx 10rpx;
  border-radius: 12rpx;
}

.stat-item.highlight {
  background: rgba(255, 193, 7, 0.3);
}

.stat-item.success {
  background: rgba(76, 175, 80, 0.3);
}

.stat-value {
  font-size: 40rpx;
  font-weight: bold;
  display: block;
}

.stat-label {
  font-size: 22rpx;
  opacity: 0.9;
  margin-top: 8rpx;
  display: block;
}

/* 高频错题区域 */
.high-freq-section {
  background: white;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.section-more {
  font-size: 24rpx;
  color: #667eea;
}

.high-freq-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.high-freq-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background: #fff5f5;
  border-radius: 12rpx;
  border-left: 4rpx solid #ef4444;
}

.word-info .word {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-right: 16rpx;
}

.word-info .phonetic {
  font-size: 24rpx;
  color: #999;
}

.error-count .count {
  font-size: 24rpx;
  color: #ef4444;
  font-weight: bold;
}

/* 筛选栏 */
.filter-bar {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
  overflow-x: auto;
  padding: 10rpx 0;
}

.filter-item {
  padding: 12rpx 24rpx;
  background: white;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #666;
  white-space: nowrap;
}

.filter-item.active {
  background: #667eea;
  color: white;
}

/* 错题列表 */
.mistakes-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.mistake-item {
  display: flex;
  justify-content: space-between;
  background: white;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.mistake-left {
  flex: 1;
}

.word-row {
  margin-bottom: 12rpx;
}

.word-row .word {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-right: 16rpx;
}

.word-row .phonetic {
  font-size: 24rpx;
  color: #999;
}

.definition {
  font-size: 26rpx;
  color: #666;
  display: block;
  margin-bottom: 16rpx;
  line-height: 1.5;
}

.tags-row {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.tag {
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}

.tag.error-type {
  background: #fef3c7;
  color: #92400e;
}

.tag.error-count {
  background: #fee2e2;
  color: #991b1b;
}

.tag.high-freq {
  background: #ef4444;
  color: white;
}

.mistake-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 12rpx;
}

.mastery-level {
  display: flex;
  gap: 6rpx;
}

.level-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #e5e7eb;
}

.level-dot.filled {
  background: #667eea;
}

.last-error {
  font-size: 22rpx;
  color: #999;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 100rpx 40rpx;
}

.empty-emoji {
  font-size: 120rpx;
  display: block;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #333;
  font-weight: bold;
  display: block;
  margin-bottom: 16rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #999;
  display: block;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 30rpx;
  color: #667eea;
  font-size: 28rpx;
}
