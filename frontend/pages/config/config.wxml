<!-- pages/config/config.wxml -->
<view class="container">
  <!-- 🆕 个人中心入口 -->
  <view class="profile-card" bindtap="goToProfile">
    <view class="profile-avatar">
      <image wx:if="{{userInfo.avatar}}" src="{{userInfo.avatar}}" mode="aspectFill"></image>
      <view wx:else class="avatar-placeholder">👤</view>
    </view>
    <view class="profile-info">
      <view class="profile-nickname">{{userInfo.nickname || '点击登录'}}</view>
      <view class="profile-stats">
        <text>学习 {{userInfo.studyDays || 0}} 天</text>
        <text class="divider">|</text>
        <text>累计 {{userInfo.totalWords || 0}} 词</text>
      </view>
    </view>
    <view class="profile-arrow">›</view>
  </view>

  <view class="card" wx:if="{{!loading}}">
    <view class="title">学习配置</view>
    
    <!-- 🆕 词库选择（支持多选）-->
    <view class="config-section">
      <view class="subtitle">选择词库（多选）</view>
      <view class="library-selector">
        <view 
          wx:for="{{libraries}}" 
          wx:key="id"
          class="library-item {{item.selected ? 'selected' : ''}}"
          data-id="{{item.id}}"
          bindtap="toggleLibrary">
          <view class="library-checkbox">
            <view class="checkbox-icon {{item.selected ? 'checked' : ''}}">
              <text wx:if="{{item.selected}}">✓</text>
            </view>
          </view>
          <view class="library-info">
            <view class="library-name">{{item.name}}</view>
            <view class="library-desc">{{item.description}}</view>
            <view class="library-count">{{item.word_count}} 词</view>
          </view>
        </view>
      </view>
      <view class="selected-hint">已选择 {{config.vocab_library.length}} 个词库</view>
    </view>
    
    <!-- 🆕 分类选择（仅当选择雅思词汇真经时显示） -->
    <view class="config-section" wx:if="{{config.vocab_library === 'zhenjing'}}">
      <view class="subtitle">选择分类</view>
      <picker 
        mode="selector" 
        range="{{categories}}" 
        range-key="name"
        value="{{categoryIndex}}"
        bindchange="selectCategory">
        <view class="category-picker">
          <block wx:if="{{categoryIndex >= 0 && categories.length > categoryIndex}}">
            {{categories[categoryIndex].name}}
          </block>
          <block wx:else>
            全部章节
          </block>
        </view>
      </picker>
      <view class="text" wx:if="{{categoryIndex >= 0 && categories.length > categoryIndex && categories[categoryIndex].word_count}}">
        共 {{categories[categoryIndex].word_count}} 个单词
      </view>
    </view>
    
    <view class="config-section">
      <view class="subtitle">每周学习天数</view>
      <view class="days-selector">
        <view 
          wx:for="{{daysOfWeek}}" 
          wx:key="value"
          class="day-item {{item.selected ? 'selected' : ''}}"
          data-value="{{item.value}}"
          bindtap="toggleDay">
          {{item.name}}
        </view>
      </view>
    </view>
    
    <view class="config-section">
      <view class="subtitle">每日新词数量</view>
      <slider 
        min="1" 
        max="100" 
        step="1" 
        value="{{config.daily_new_words_count}}" 
        bindchange="updateDailyCount"
        show-value />
      <view class="text">建议：20-50个单词/天</view>
    </view>
    
    <view class="config-section">
      <view class="subtitle">复习提醒时间</view>
      <picker mode="time" value="{{config.review_time}}" bindchange="updateReviewTime">
        <view class="time-picker">
          {{config.review_time}}
        </view>
      </picker>
      <view class="text">系统会在指定时间提醒你进行复习</view>
    </view>
    
    <button class="button" bindtap="saveConfig">保存配置</button>
    <button class="button" style="background:#666" bindtap="goBackHome">返回首页</button>
  </view>
  
  <view class="card" wx:else>
    <view class="loading">加载配置中...</view>
  </view>
</view>