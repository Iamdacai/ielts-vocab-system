/* pages/config/config.wxss */

/* 🆕 个人中心卡片 */
.profile-card {
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  border-radius: 20rpx;
  padding: 30rpx;
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(24, 144, 255, 0.3);
}

.profile-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  overflow: hidden;
  margin-right: 20rpx;
}

.profile-avatar image {
  width: 100%;
  height: 100%;
}

.avatar-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 50rpx;
  color: #ffffff;
}

.profile-info {
  flex: 1;
}

.profile-nickname {
  font-size: 32rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 8rpx;
}

.profile-stats {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  display: flex;
  gap: 10rpx;
}

.profile-stats .divider {
  color: rgba(255, 255, 255, 0.5);
}

.profile-arrow {
  font-size: 48rpx;
  color: rgba(255, 255, 255, 0.8);
}

.config-section {
  margin-bottom: 40rpx;
}

/* 🆕 词库选择器样式（支持多选）*/
.library-selector {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: 20rpx;
}

.library-item {
  padding: 30rpx;
  border: 2rpx solid #ddd;
  border-radius: 16rpx;
  background: #fff;
  transition: all 0.3s;
  cursor: pointer;
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.library-item:active {
  opacity: 0.7;
  transform: scale(0.98);
}

.library-item.selected {
  border-color: #007AFF;
  background: #f0f7ff;
  box-shadow: 0 2px 8px rgba(0, 122, 255, 0.2);
}

/* 🆕 复选框样式 */
.library-checkbox {
  flex-shrink: 0;
  width: 48rpx;
  height: 48rpx;
}

.checkbox-icon {
  width: 100%;
  height: 100%;
  border: 3rpx solid #ddd;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
  background: #fff;
}

.checkbox-icon.checked {
  background: #007AFF;
  border-color: #007AFF;
}

.checkbox-icon text {
  color: #fff;
  font-size: 28rpx;
  font-weight: bold;
}

.library-info {
  flex: 1;
}

.library-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.library-desc {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.library-count {
  font-size: 24rpx;
  color: #007AFF;
  font-weight: 500;
}

/* 🆕 已选词库提示 */
.selected-hint {
  margin-top: 15rpx;
  padding: 15rpx;
  background: #f0f7ff;
  border-radius: 12rpx;
  text-align: center;
  font-size: 26rpx;
  color: #007AFF;
}

/* 🆕 分类选择器样式 */
.category-picker {
  padding: 25rpx;
  background: #f8f8f8;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #333;
  text-align: center;
  margin-top: 15rpx;
  border: 2rpx solid #eee;
}

.days-selector {
  display: flex;
  flex-wrap: wrap;
  gap: 15rpx;
  margin-top: 20rpx;
}

.day-item {
  padding: 15rpx 25rpx;
  border: 2rpx solid #ddd !important;
  border-radius: 50rpx;
  font-size: 26rpx;
  color: #666 !important;
  background: #fff !important;
  cursor: pointer;
  user-select: none;
  transition: all 0.2s ease;
}

.day-item:active {
  opacity: 0.6;
  transform: scale(0.95);
}

.day-item.selected {
  background: #007AFF !important;
  color: #ffffff !important;
  border-color: #007AFF !important;
  box-shadow: 0 2px 8px rgba(0, 122, 255, 0.4);
}

.time-picker {
  padding: 20rpx;
  background: #f8f8f8;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #333;
  text-align: center;
  margin-top: 15rpx;
}

.loading {
  padding: 60rpx 0;
  text-align: center;
  color: #999;
}