/* pages/config/config.wxss */
.config-section {
  margin-bottom: 40rpx;
}

/* 🆕 词库选择器样式 */
.library-selector {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: 20rpx;
}

.library-item {
  padding: 30rpx;
  border: 2rpx solid #ddd;
  border-radius: 16rpx;
  background: #fff;
  transition: all 0.3s;
  cursor: pointer;
}

.library-item:active {
  opacity: 0.7;
  transform: scale(0.98);
}

.library-item.selected {
  border-color: #007AFF;
  background: #f0f7ff;
  box-shadow: 0 2px 8px rgba(0, 122, 255, 0.2);
}

.library-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.library-desc {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.library-count {
  font-size: 24rpx;
  color: #007AFF;
  font-weight: 500;
}

/* 🆕 分类选择器样式 */
.category-picker {
  padding: 25rpx;
  background: #f8f8f8;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #333;
  text-align: center;
  margin-top: 15rpx;
  border: 2rpx solid #eee;
}

.days-selector {
  display: flex;
  flex-wrap: wrap;
  gap: 15rpx;
  margin-top: 20rpx;
}

.day-item {
  padding: 15rpx 25rpx;
  border: 2rpx solid #ddd !important;
  border-radius: 50rpx;
  font-size: 26rpx;
  color: #666 !important;
  background: #fff !important;
  cursor: pointer;
  user-select: none;
  transition: all 0.2s ease;
}

.day-item:active {
  opacity: 0.6;
  transform: scale(0.95);
}

.day-item.selected {
  background: #007AFF !important;
  color: #ffffff !important;
  border-color: #007AFF !important;
  box-shadow: 0 2px 8px rgba(0, 122, 255, 0.4);
}

.time-picker {
  padding: 20rpx;
  background: #f8f8f8;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #333;
  text-align: center;
  margin-top: 15rpx;
}

.loading {
  padding: 60rpx 0;
  text-align: center;
  color: #999;
}