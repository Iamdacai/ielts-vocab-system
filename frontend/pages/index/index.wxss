/* pages/index/index.wxss - 优化版 */
.container {
  padding: 20rpx;
  background: linear-gradient(180deg, #1f2937 0%, #111827 100%);
  min-height: 100vh;
}

/* 头部 */
.header {
  text-align: center;
  padding: 40rpx 0;
}

.header .title {
  font-size: 48rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 10rpx;
}

.header .subtitle {
  font-size: 28rpx;
  color: #9ca3af;
}

/* 卡片 */
.card {
  background: #1f2937;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.3);
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 20rpx;
}

/* 登录页面 */
.login-section {
  text-align: center;
  padding: 80rpx 40rpx;
}

.login-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.login-section .title {
  font-size: 40rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 10rpx;
}

.login-section .subtitle {
  font-size: 28rpx;
  color: #9ca3af;
  margin-bottom: 40rpx;
}

.login-button {
  background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
  color: white;
  border: none;
  border-radius: 50rpx;
  padding: 30rpx 60rpx;
  font-size: 32rpx;
  font-weight: bold;
  box-shadow: 0 8rpx 20rpx rgba(59, 130, 246, 0.4);
}

/* 九宫格记忆轮 - 🆕 圆圈布局 */
.memory-wheel-card {
  text-align: center;
}

.wheel-container {
  display: flex;
  justify-content: center;
  margin: 20rpx 0;
}

.memory-wheel-circle {
  position: relative;
  width: 320rpx;
  height: 320rpx;
  margin: 0 auto;
}

/* 阶段圆圈 */
.stage-circle {
  position: absolute;
  width: 70rpx;
  height: 70rpx;
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.3);
  transform-origin: center center;
  transition: transform 0.2s ease;
}

.stage-circle:active {
  transform: scale(0.95);
}

.stage-count {
  font-size: 28rpx;
  font-weight: bold;
  color: #ffffff;
  line-height: 1;
}

.stage-label {
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.9);
  line-height: 1;
  margin-top: 4rpx;
}

/* 中心按钮 */
.center-button {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 20rpx rgba(239, 68, 68, 0.5);
  border: 4rpx solid #1f2937;
}

.center-text {
  font-size: 22rpx;
  font-weight: bold;
  color: #ffffff;
  line-height: 1;
}

.center-subtitle {
  font-size: 16rpx;
  color: rgba(255, 255, 255, 0.9);
  line-height: 1;
  margin-top: 6rpx;
}

.wheel-stats {
  display: flex;
  justify-content: space-around;
  margin-top: 30rpx;
  padding-top: 30rpx;
  border-top: 1rpx solid #374151;
}

.wheel-stats .stat-item {
  text-align: center;
}

.wheel-stats .stat-label {
  font-size: 24rpx;
  color: #9ca3af;
  margin-bottom: 8rpx;
}

.wheel-stats .stat-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #ffffff;
}

/* 统计网格 */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.stat-item {
  text-align: center;
  padding: 20rpx;
  background: #111827;
  border-radius: 16rpx;
}

.stat-number {
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #9ca3af;
}

/* 🆕 学习数据网格 */
.data-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.data-item {
  text-align: center;
  padding: 25rpx 15rpx;
  background: linear-gradient(135deg, rgba(59, 130, 246, 0.1) 0%, rgba(37, 99, 235, 0.05) 100%);
  border-radius: 16rpx;
  border: 1rpx solid rgba(59, 130, 246, 0.2);
}

.data-icon {
  font-size: 36rpx;
  margin-bottom: 10rpx;
}

.data-value {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
  line-height: 1;
}

.data-label {
  font-size: 22rpx;
  color: #9ca3af;
}

/* 颜色 */
.primary-color {
  color: #3b82f6;
}

.success-color {
  color: #22c55e;
}

.warning-color {
  color: #f59e0b;
}

.info-color {
  color: #06b6d4;
}

.highlight-color {
  color: #ec4899;
}

/* 操作按钮 - 🆕 横向排列 */
.action-buttons-row {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  gap: 16rpx;
}

.action-button-small {
  flex: 1;
  border: none;
  border-radius: 12rpx;
  padding: 20rpx 10rpx;
  font-size: 24rpx;
  font-weight: bold;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.2);
  margin: 0;
}

.action-button-small.primary {
  background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%);
  color: white;
}

.action-button-small.warning {
  background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
  color: white;
}

.action-button-small.success {
  background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
  color: white;
}

/* 功能列表 */
.feature-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.feature-item {
  font-size: 28rpx;
  color: #d1d5db;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #374151;
}

.feature-item:last-child {
  border-bottom: none;
}

/* 加载状态 */
.loading {
  text-align: center;
  padding: 40rpx;
  color: #9ca3af;
  font-size: 28rpx;
}
