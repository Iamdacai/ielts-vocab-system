/* pages/index/index.wxss - 简化版 */
.container {
  padding: 20rpx;
  background: linear-gradient(180deg, #1f2937 0%, #111827 100%);
  min-height: 100vh;
}

/* 顶部导航栏 */
.header {
  text-align: center;
  padding: 40rpx 20rpx;
  margin-bottom: 20rpx;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 10rpx;
}

.subtitle {
  font-size: 26rpx;
  color: #9ca3af;
}

/* 通用卡片样式 */
.card {
  background: #1f2937;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.3);
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 20rpx;
}

/* 登录区域 */
.login-section {
  text-align: center;
  padding: 60rpx 40rpx;
}

.login-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.features-preview {
  margin: 40rpx 0;
  text-align: left;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
  padding: 30rpx;
}

.feature-item {
  font-size: 28rpx;
  color: #ffffff;
  padding: 12rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
}

.feature-item:last-child {
  border-bottom: none;
}

.login-button {
  background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%);
  color: #ffffff;
  border: none;
  border-radius: 50rpx;
  padding: 28rpx 60rpx;
  font-size: 32rpx;
  font-weight: bold;
  margin-top: 40rpx;
  box-shadow: 0 4rpx 12rpx rgba(34, 197, 94, 0.3);
}

/* 用户信息卡片 */
.user-card {
  padding: 0;
  overflow: hidden;
}

.user-info {
  display: flex;
  align-items: center;
  padding: 30rpx;
  background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
}

.user-avatar {
  font-size: 80rpx;
  margin-right: 20rpx;
}

.user-details {
  flex: 1;
}

.user-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 8rpx;
}

.user-level {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 核心统计 - 紧凑版 */
.data-grid-compact {
  display: flex;
  justify-content: space-around;
  gap: 20rpx;
}

.data-item-compact {
  text-align: center;
  flex: 1;
  padding: 20rpx 10rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
}

.data-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 8rpx;
}

.data-label {
  font-size: 24rpx;
  color: #9ca3af;
}

.success-color {
  color: #22c55e !important;
}

.primary-color {
  color: #3b82f6 !important;
}

.warning-color {
  color: #f59e0b !important;
}

/* 任务列表 */
.task-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.task-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
}

.task-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
}

.task-info {
  flex: 1;
}

.task-title {
  font-size: 28rpx;
  color: #ffffff;
  font-weight: bold;
  margin-bottom: 6rpx;
}

.task-desc {
  font-size: 24rpx;
  color: #9ca3af;
}

.task-button {
  padding: 16rpx 32rpx;
  border-radius: 50rpx;
  font-size: 26rpx;
  font-weight: bold;
  border: none;
  min-width: 140rpx;
}

.task-button.primary {
  background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
  color: #ffffff;
}

.task-button.warning {
  background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
  color: #ffffff;
}

.task-button:active {
  transform: scale(0.95);
}

/* 快捷操作按钮 */
.action-buttons-row {
  display: flex;
  gap: 20rpx;
  justify-content: space-between;
}

.action-button-small {
  flex: 1;
  padding: 24rpx 16rpx;
  border-radius: 20rpx;
  font-size: 26rpx;
  font-weight: bold;
  border: none;
}

.action-button-small.primary {
  background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
  color: #ffffff;
}

.action-button-small.warning {
  background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
  color: #ffffff;
}

.action-button-small.success {
  background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%);
  color: #ffffff;
}

.action-button-small:active {
  transform: scale(0.95);
}

/* 掌握率区域 */
.mastery-section {
  text-align: center;
  padding: 20rpx 0;
}

.mastery-value {
  font-size: 64rpx;
  font-weight: bold;
  color: #22c55e;
  margin-bottom: 20rpx;
}

.mastery-bar {
  width: 100%;
  height: 20rpx;
  background: #374151;
  border-radius: 10rpx;
  overflow: hidden;
  margin-bottom: 15rpx;
}

.mastery-fill {
  height: 100%;
  background: linear-gradient(90deg, #22c55e 0%, #16a34a 100%);
  transition: width 0.3s ease;
}

.mastery-desc {
  font-size: 24rpx;
  color: #9ca3af;
}

/* 🤖 AI 功能专区 */
.ai-section {
  background: linear-gradient(135deg, #1e3a8a 0%, #1e40af 100%);
  border: 2rpx solid #3b82f6;
}

.ai-section .card-title {
  color: #ffffff;
}

.ai-feature-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.ai-feature-item {
  background: rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  padding: 24rpx 16rpx;
  text-align: center;
  border: 1rpx solid rgba(59, 130, 246, 0.3);
  transition: all 0.3s;
}

.ai-feature-item:active {
  background: rgba(255, 255, 255, 0.2);
  transform: scale(0.98);
}

.ai-feature-icon {
  font-size: 56rpx;
  margin-bottom: 12rpx;
}

.ai-feature-name {
  font-size: 26rpx;
  color: #ffffff;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.ai-feature-desc {
  font-size: 22rpx;
  color: #93c5fd;
  line-height: 1.4;
}

/* 🎯 专项练习专区 */
.practice-section {
  background: linear-gradient(135deg, #7c3aed 0%, #6d28d9 100%);
  border: 2rpx solid #a78bfa;
}

.practice-section .card-title {
  color: #ffffff;
}

.practice-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}

.practice-item {
  background: rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  padding: 24rpx 12rpx;
  text-align: center;
  border: 1rpx solid rgba(167, 139, 250, 0.3);
  transition: all 0.3s;
  cursor: pointer;
  position: relative;
  z-index: 1;
}

.practice-item:active {
  background: rgba(255, 255, 255, 0.2);
  transform: scale(0.95);
}

.practice-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.practice-name {
  font-size: 24rpx;
  color: #ffffff;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.practice-desc {
  font-size: 20rpx;
  color: #c4b5fd;
  line-height: 1.3;
}

/* 📚 学习工具 */
.tools-section {
  background: linear-gradient(135deg, #059669 0%, #047857 100%);
  border: 2rpx solid #34d399;
}

.tools-section .card-title {
  color: #ffffff;
}

.tools-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}

.tool-item {
  background: rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  padding: 24rpx 12rpx;
  text-align: center;
  border: 1rpx solid rgba(52, 211, 153, 0.3);
  transition: all 0.3s;
}

.tool-item:active {
  background: rgba(255, 255, 255, 0.2);
  transform: scale(0.95);
}

.tool-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.tool-name {
  font-size: 24rpx;
  color: #ffffff;
  font-weight: bold;
}
