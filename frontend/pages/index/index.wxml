<!--pages/index/index.wxml - 优化版：九宫格可视化-->
<view class="container">
  <!-- 顶部导航栏 -->
  <view class="header">
    <view class="title">🎯 雅思智能背单词</view>
    <view class="subtitle">每天 15 分钟，雅思 7+ 不是梦</view>
  </view>

  <view wx:if="{{!hasLogin}}" class="login-section card">
    <view class="login-icon">📚</view>
    <view class="title">欢迎使用雅思背单词</view>
    <view class="subtitle">基于艾宾浩斯遗忘曲线的科学记忆系统</view>
    <button class="login-button" bindtap="handleLogin">
      微信登录开始学习
    </button>
  </view>

  <view wx:else class="dashboard-section">
    <!-- 九宫格记忆轮 -->
    <view class="card memory-wheel-card">
      <view class="card-title">📊 记忆九宫格</view>
      <view class="wheel-container">
        <view class="memory-wheel" style="width: 300px; height: 300px;">
          <svg width="300" height="300" viewBox="0 0 200 200">
            <!-- 8 个扇区 -->
            <block wx:for="{{memoryWheelData}}" wx:key="id">
              <path
                d="{{item.path}}"
                fill="{{item.color}}"
                stroke="#1f2937"
                stroke-width="1"
              />
              <text
                wx:if="{{item.count > 0}}"
                x="{{item.centerX}}"
                y="{{item.centerY}}"
                text-anchor="middle"
                dominant-baseline="middle"
                fill="white"
                font-size="14"
                font-weight="bold"
              >
                {{item.count}}
              </text>
              <text
                x="{{item.labelX}}"
                y="{{item.labelY}}"
                text-anchor="middle"
                fill="white"
                font-size="10"
                opacity="0.8"
              >
                {{item.label}}
              </text>
            </block>
            
            <!-- 中心按钮 -->
            <circle cx="100" cy="100" r="35" fill="#ef4444" bindtap="startReview" />
            <text x="100" y="95" text-anchor="middle" fill="white" font-size="12" font-weight="bold">START</text>
            <text x="100" y="115" text-anchor="middle" fill="white" font-size="10">{{dueWordsCount}}词待复习</text>
            <polygon points="95,92 95,108 110,100" fill="white" />
          </svg>
        </view>
      </view>
      
      <!-- 统计信息 -->
      <view class="wheel-stats">
        <view class="stat-item">
          <view class="stat-label">总词汇量</view>
          <view class="stat-value">{{stats.total_words}}</view>
        </view>
        <view class="stat-item">
          <view class="stat-label">掌握率</view>
          <view class="stat-value success-color">{{masteryRate}}%</view>
        </view>
      </view>
    </view>

    <!-- 学习统计 -->
    <view class="card">
      <view class="card-title">📈 今日学习</view>
      <view class="stats-grid">
        <view class="stat-item">
          <view class="stat-number primary-color">{{todayStats.newWords}}</view>
          <view class="stat-label">新学单词</view>
        </view>
        <view class="stat-item">
          <view class="stat-number warning-color">{{todayStats.reviewWords}}</view>
          <view class="stat-label">待复习</view>
        </view>
        <view class="stat-item">
          <view class="stat-number success-color">{{todayStats.masteredWords}}</view>
          <view class="stat-label">已掌握</view>
        </view>
      </view>
    </view>

    <!-- 快捷操作 -->
    <view class="card">
      <view class="card-title">🚀 开始学习</view>
      <view class="action-buttons">
        <button class="action-button primary" bindtap="navigateToLearning">
          🟢 新词学习
        </button>
        <button class="action-button warning" bindtap="navigateToReview">
          🟠 复习单词
        </button>
        <button class="action-button success" bindtap="navigateToConfig">
          ⚙️ 学习设置
        </button>
      </view>
    </view>

    <!-- 功能特色 -->
    <view class="card">
      <view class="card-title">✨ 功能特色</view>
      <view class="feature-list">
        <view class="feature-item">🎯 九宫格艾宾浩斯记忆法</view>
        <view class="feature-item">📚 剑桥雅思 1-18 完整词汇</view>
        <view class="feature-item">🔊 智能发音评测</view>
        <view class="feature-item">📊 个性化学习报告</view>
      </view>
    </view>
  </view>
</view>
