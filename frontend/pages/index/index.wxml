<!--pages/index/index.wxml - 登录后显示功能-->
<view class="container">
  <!-- 顶部导航栏 -->
  <view class="header">
    <view class="title">🎯 雅思智能背单词</view>
    <view class="subtitle">每天 15 分钟，雅思 7+ 不是梦</view>
  </view>

  <!-- 登录前：只显示登录按钮 -->
  <view wx:if="{{!hasLogin}}" class="login-section card">
    <view class="login-icon">📚</view>
    <view class="title">欢迎使用雅思背单词</view>
    <view class="subtitle">基于艾宾浩斯遗忘曲线的科学记忆系统</view>
    <view class="features-preview">
      <view class="feature-item">✅ 艾宾浩斯遗忘曲线复习</view>
      <view class="feature-item">✅ 剑桥雅思 1-18 完整词汇</view>
      <view class="feature-item">✅ 智能发音评测</view>
      <view class="feature-item">✅ 个性化学习报告</view>
    </view>
    <button class="login-button" bindtap="handleLogin">
      微信登录开始学习
    </button>
  </view>

  <!-- 🆕 登录后：显示完整功能（自动登录，不再显示登录前状态） -->
  <view class="dashboard-section">
    <!-- 用户信息卡片 -->
    <view class="card user-card">
      <view class="user-info">
        <view class="user-avatar">👤</view>
        <view class="user-details">
          <view class="user-name">{{userInfo.nickname || '同学'}}</view>
          <view class="user-stats-inline">
            <text>学习 {{userInfo.studyDays || 0}} 天</text>
            <text class="divider">|</text>
            <text>累计 {{userInfo.totalWords || 0}} 词</text>
          </view>
        </view>
      </view>
      <view class="user-actions" bindtap="goToProfile">
        <view class="action-icon">⚙️</view>
      </view>
    </view>

    <!-- 核心统计 -->
    <view class="card">
      <view class="card-title">📊 学习概览</view>
      <view class="data-grid-compact">
        <view class="data-item-compact">
          <view class="data-value">{{stats.total_words}}</view>
          <view class="data-label">总词汇</view>
        </view>
        <view class="data-item-compact">
          <view class="data-value success-color">{{stats.mastered_words}}</view>
          <view class="data-label">已掌握</view>
        </view>
        <view class="data-item-compact">
          <view class="data-value primary-color">{{dueWordsCount}}</view>
          <view class="data-label">待复习</view>
        </view>
      </view>
    </view>

    <!-- 今日任务 -->
    <view class="card">
      <view class="card-title">📅 今日任务</view>
      <view class="task-list">
        <view class="task-item">
          <view class="task-icon">📖</view>
          <view class="task-info">
            <view class="task-title">新词学习</view>
            <view class="task-desc">目标：{{todayStats.newWords}} 个</view>
          </view>
          <button class="task-button primary" bindtap="navigateToLearning">开始</button>
        </view>
        <view class="task-item">
          <view class="task-icon">🔁</view>
          <view class="task-info">
            <view class="task-title">复习巩固</view>
            <view class="task-desc">{{dueWordsCount}} 个待复习</view>
          </view>
          <button class="task-button warning" bindtap="navigateToReview">
            {{dueWordsCount > 0 ? '开始' : '已完成'}}
          </button>
        </view>
      </view>
    </view>



    <!-- 学习进度 -->
    <view class="card">
      <view class="card-title">📈 掌握率</view>
      <view class="mastery-section">
        <view class="mastery-value">{{masteryRate}}%</view>
        <view class="mastery-bar">
          <view class="mastery-fill" style="width: {{masteryRate}}%"></view>
        </view>
        <view class="mastery-desc">已掌握 {{stats.mastered_words}} / 总计 {{stats.total_words}}</view>
      </view>
    </view>

    <!-- 🤖 AI 功能专区 -->
    <view class="card ai-section">
      <view class="card-title">🤖 AI 智能陪练</view>
      <view class="ai-feature-grid">
        <view class="ai-feature-item" bindtap="goToAIInterests">
          <view class="ai-feature-icon">📝</view>
          <view class="ai-feature-name">AI 定制例句</view>
          <view class="ai-feature-desc">根据兴趣生成</view>
        </view>
        <view class="ai-feature-item" bindtap="goToSpeaking">
          <view class="ai-feature-icon">🎤</view>
          <view class="ai-feature-name">口语陪练</view>
          <view class="ai-feature-desc">AI 智能评分</view>
        </view>
        <view class="ai-feature-item" bindtap="goToWriting">
          <view class="ai-feature-icon">✍️</view>
          <view class="ai-feature-name">写作批改</view>
          <view class="ai-feature-desc">四维评分系统</view>
        </view>
      </view>
    </view>

    <!-- 🤖 AI 功能专区 -->
    <view class="card ai-section">
      <view class="card-title">🤖 AI 智能陪练</view>
      <view class="ai-feature-grid">
        <view class="ai-feature-item" bindtap="goToAIInterests">
          <view class="ai-feature-icon">📝</view>
          <view class="ai-feature-name">AI 定制例句</view>
          <view class="ai-feature-desc">根据兴趣生成</view>
        </view>
        <view class="ai-feature-item" bindtap="goToSpeaking">
          <view class="ai-feature-icon">🎤</view>
          <view class="ai-feature-name">口语陪练</view>
          <view class="ai-feature-desc">AI 智能评分</view>
        </view>
        <view class="ai-feature-item" bindtap="goToWriting">
          <view class="ai-feature-icon">✍️</view>
          <view class="ai-feature-name">写作批改</view>
          <view class="ai-feature-desc">四维评分系统</view>
        </view>
      </view>
    </view>
  </view>
</view>
