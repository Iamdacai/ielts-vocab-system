/* pages/review/review.wxss - 复习课管理系统 v2.0 */
.container {
  padding: 20rpx;
  background: linear-gradient(180deg, #1f2937 0%, #111827 100%);
  min-height: 100vh;
}

/* ========== 九宫格总览模式 ========== */
.overview-mode {
  padding-bottom: 40rpx;
}

/* 导航栏 */
.nav-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 10rpx;
  margin-bottom: 20rpx;
}

.back-btn {
  font-size: 28rpx;
  color: #22c55e;
  font-weight: bold;
}

.page-title {
  font-size: 32rpx;
  color: #ffffff;
  font-weight: bold;
}

.placeholder {
  width: 100rpx;
}

/* 九宫格区域 */
.wheel-section {
  background: #1f2937;
  border-radius: 24rpx;
  padding: 40rpx 20rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.3);
}

.section-title {
  font-size: 32rpx;
  color: #ffffff;
  font-weight: bold;
  text-align: center;
  margin-bottom: 30rpx;
}

.wheel-container {
  position: relative;
  width: 300rpx;  /* 🆕 缩小一半 */
  height: 300rpx;
  margin: 0 auto;
}

.wheel-center {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 80rpx;  /* 🆕 缩小一半 */
  height: 80rpx;
  background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(59, 130, 246, 0.3);
  z-index: 10;
}

.center-text {
  font-size: 24rpx;  /* 🆕 缩小字体 */
  font-weight: bold;
  color: #ffffff;
}

.center-label {
  font-size: 14rpx;  /* 🆕 缩小字体 */
  color: rgba(255, 255, 255, 0.8);
  margin-top: 2rpx;
}

.wheel-node {
  position: absolute;
  width: 80rpx;  /* 🆕 缩小一半 */
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.3);
  transition: all 0.3s ease;
}

.wheel-node:active {
  transform: scale(0.95);
}

.node-count {
  font-size: 20rpx;  /* 🆕 缩小字体 */
  font-weight: bold;
  color: #ffffff;
  line-height: 1;
}

.node-label {
  font-size: 12rpx;  /* 🆕 缩小字体 */
  color: rgba(255, 255, 255, 0.9);
  margin-top: 2rpx;
  white-space: nowrap;
}

.wheel-legend {
  display: flex;
  justify-content: center;
  gap: 40rpx;
  margin-top: 30rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 24rpx;
  color: #9ca3af;
}

.legend-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
}

/* 今日复习课区域 */
.session-section {
  margin-bottom: 30rpx;
}

.session-card {
  background: #1f2937;
  border-radius: 24rpx;
  padding: 30rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.3);
}

.session-card.empty {
  text-align: center;
  padding: 60rpx 30rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #ffffff;
  margin-bottom: 30rpx;
}

.session-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.session-status {
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 50rpx;
  font-weight: bold;
}

.session-status.pending {
  background: #f59e0b;
  color: #000;
}

.session-status.in_progress {
  background: #3b82f6;
  color: #fff;
}

.session-status.completed {
  background: #22c55e;
  color: #fff;
}

.session-date {
  font-size: 24rpx;
  color: #9ca3af;
}

.session-info {
  margin-bottom: 20rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: #9ca3af;
}

.info-value {
  font-size: 28rpx;
  color: #ffffff;
  font-weight: bold;
}

.info-value.highlight {
  color: #f59e0b;
}

.session-progress {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.progress-bar {
  flex: 1;
  height: 16rpx;
  background: #374151;
  border-radius: 8rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #22c55e 0%, #16a34a 100%);
  transition: width 0.3s ease;
}

.progress-text {
  font-size: 24rpx;
  color: #22c55e;
  font-weight: bold;
  min-width: 60rpx;
}

.start-button {
  width: 100%;
  background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
  color: #ffffff;
  border: none;
  border-radius: 50rpx;
  padding: 28rpx;
  font-size: 32rpx;
  font-weight: bold;
  box-shadow: 0 4rpx 12rpx rgba(245, 158, 11, 0.3);
}

.start-button:active {
  transform: scale(0.98);
}

.complete-message {
  text-align: center;
  font-size: 32rpx;
  color: #22c55e;
  font-weight: bold;
  padding: 20rpx;
}

.learn-button {
  background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
  color: #ffffff;
  border: none;
  border-radius: 50rpx;
  padding: 24rpx 60rpx;
  font-size: 30rpx;
  font-weight: bold;
}

/* 统计区域 */
.stats-section {
  margin-bottom: 30rpx;
}

.stats-grid {
  display: flex;
  gap: 20rpx;
}

.stat-card {
  flex: 1;
  background: #1f2937;
  border-radius: 20rpx;
  padding: 30rpx 20rpx;
  text-align: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.2);
}

.stat-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #22c55e;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #9ca3af;
}

/* 加载中 */
.loading-container {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100vh;
}

.loading-text {
  font-size: 32rpx;
  color: #9ca3af;
}

/* ========== 复习答题模式（原有样式保留） ========== */

/* 头部进度 */
.header {
  margin-bottom: 30rpx;
}

.progress-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.progress-text {
  font-size: 28rpx;
  color: #22c55e;
  font-weight: bold;
}

.progress-count {
  font-size: 24rpx;
  color: #9ca3af;
}

.progress-bar {
  width: 100%;
  height: 12rpx;
  background: #374151;
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #22c55e 0%, #16a34a 100%);
  transition: width 0.3s ease;
}

/* 单词卡片 */
.word-card {
  background: #1f2937;
  border-radius: 20rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.3);
}

.word-header {
  text-align: center;
  margin-bottom: 30rpx;
}

.word-text {
  font-size: 48rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 10rpx;
}

.word-phonetic {
  font-size: 28rpx;
  color: #9ca3af;
  font-family: monospace;
}

/* 🆕 发音播放按钮 */
.audio-play-btn {
  display: inline-block;
  margin-top: 10rpx;
  font-size: 40rpx;
  cursor: pointer;
  padding: 10rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
  width: 60rpx;
  height: 60rpx;
  line-height: 60rpx;
  text-align: center;
  transition: all 0.2s ease;
}

.audio-play-btn:active {
  background: rgba(255, 255, 255, 0.2);
  transform: scale(0.95);
}

.phrase-badge {
  display: inline-block;
  background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
  color: white;
  padding: 8rpx 24rpx;
  border-radius: 50rpx;
  font-size: 24rpx;
  margin-bottom: 20rpx;
}

/* 🆕 提示区域（未显示答案时） */
.hint-section {
  text-align: center;
  padding: 60rpx 20rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.hint-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.hint-text {
  font-size: 32rpx;
  color: #ffffff;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.hint-subtext {
  font-size: 24rpx;
  color: #9ca3af;
}

/* 🆕 答案区域（点击"不认识"后显示） */
.answer-section {
  margin-top: 20rpx;
}

/* 释义区域 */
.translation-section {
  background: #111827;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  position: relative;
}

.translation-title {
  font-size: 24rpx;
  color: #9ca3af;
  margin-bottom: 10rpx;
}

.translation-text {
  font-size: 32rpx;
  color: #22c55e;
  font-weight: bold;
  line-height: 1.6;
}

.pos-tag {
  display: inline-block;
  background: #374151;
  color: #60a5fa;
  padding: 6rpx 16rpx;
  border-radius: 50rpx;
  font-size: 22rpx;
  margin-top: 10rpx;
}

/* 例句区域 */
.example-section {
  background: #111827;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.example-title {
  font-size: 24rpx;
  color: #9ca3af;
  margin-bottom: 15rpx;
}

/* 🆕 例句列表项 */
.example-item {
  background: rgba(255, 255, 255, 0.05);
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 15rpx;
}

.example-item:last-child {
  margin-bottom: 0;
}

.example-text {
  font-size: 28rpx;
  color: #ffffff;
  line-height: 1.6;
  margin-bottom: 10rpx;
}

.example-translation {
  font-size: 26rpx;
  color: #9ca3af;
  line-height: 1.5;
}

.audio-buttons {
  display: flex;
  gap: 20rpx;
  margin-top: 20rpx;
}

.audio-button {
  flex: 1;
  background: #374151;
  color: white;
  border: none;
  border-radius: 12rpx;
  padding: 16rpx;
  font-size: 24rpx;
}

/* 同义替换 */
.synonyms-section {
  background: #111827;
  border-radius: 16rpx;
  padding: 24rpx;
}

.synonyms-title {
  font-size: 24rpx;
  color: #9ca3af;
  margin-bottom: 15rpx;
}

.synonyms-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.synonym-item {
  background: #374151;
  color: #60a5fa;
  padding: 10rpx 20rpx;
  border-radius: 50rpx;
  font-size: 24rpx;
}

/* 剪纸盒操作按钮 */
.paper-cut-actions {
  margin-bottom: 30rpx;
}

.action-buttons {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.action-button {
  flex: 1;
  border: none;
  border-radius: 20rpx;
  padding: 30rpx;
  font-size: 32rpx;
  font-weight: bold;
}

.action-button.unknown {
  background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
  color: white;
}

.action-button.known {
  background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%);
  color: white;
}

.hint-text {
  text-align: center;
  font-size: 24rpx;
  color: #9ca3af;
}

/* 三箱统计 */
.three-boxes {
  display: flex;
  justify-content: space-around;
  margin-bottom: 30rpx;
}

.box {
  text-align: center;
  padding: 20rpx;
  border-radius: 16rpx;
  min-width: 120rpx;
}

.box.mastered {
  background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%);
}

.box.pending {
  background: linear-gradient(135deg, #6b7280 0%, #4b5563 100%);
}

.box.unknown {
  background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
}

.box-icon {
  font-size: 32rpx;
  margin-bottom: 8rpx;
}

.box-count {
  font-size: 36rpx;
  font-weight: bold;
  color: white;
  margin-bottom: 4rpx;
}

.box-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 完成模态框 */
.complete-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.8);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.complete-content {
  background: #1f2937;
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  width: 80%;
  max-width: 600rpx;
  text-align: center;
}

.complete-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.complete-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 40rpx;
}

.complete-stats {
  display: flex;
  justify-content: space-around;
  margin-bottom: 40rpx;
}

.complete-stat {
  text-align: center;
}

.stat-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #9ca3af;
}

.success-color {
  color: #22c55e !important;
}

.warning-color {
  color: #f59e0b !important;
}

.complete-button {
  background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
  color: white;
  border: none;
  border-radius: 50rpx;
  padding: 24rpx 60rpx;
  font-size: 32rpx;
  font-weight: bold;
}

/* 🆕 发音练习 */
.pronunciation-practice {
  margin: 30rpx 0;
  padding: 30rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 20rpx;
  text-align: center;
}

.practice-button {
  background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
  color: white;
  border: none;
  border-radius: 50rpx;
  padding: 24rpx 60rpx;
  font-size: 32rpx;
  font-weight: bold;
  box-shadow: 0 4rpx 12rpx rgba(59, 130, 246, 0.3);
}

.practice-button:active {
  transform: scale(0.98);
}

.recording-status {
  margin-top: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  color: #ef4444;
  font-size: 28rpx;
  font-weight: bold;
}

.recording-indicator {
  width: 20rpx;
  height: 20rpx;
  background: #ef4444;
  border-radius: 50%;
  animation: pulse 1s infinite;
}

@keyframes pulse {
  0%, 100% {
    opacity: 1;
    transform: scale(1);
  }
  50% {
    opacity: 0.5;
    transform: scale(1.2);
  }
}

.pronunciation-result {
  margin-top: 30rpx;
  padding: 30rpx;
  background: rgba(34, 197, 94, 0.1);
  border-radius: 20rpx;
  border: 2rpx solid rgba(34, 197, 94, 0.3);
}

.score-display {
  margin-bottom: 20rpx;
}

.score-number {
  font-size: 80rpx;
  font-weight: bold;
  color: #22c55e;
  line-height: 1;
}

.score-label {
  font-size: 28rpx;
  color: #9ca3af;
  margin-left: 10rpx;
}

.feedback-text {
  font-size: 28rpx;
  color: #ffffff;
  margin-bottom: 20rpx;
  line-height: 1.5;
}

.score-details {
  font-size: 24rpx;
  color: #9ca3af;
  margin-bottom: 20rpx;
}

.retry-button {
  background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
  color: white;
  border: none;
  border-radius: 50rpx;
  padding: 20rpx 40rpx;
  font-size: 28rpx;
  font-weight: bold;
}

.retry-button:active {
  transform: scale(0.98);
}
