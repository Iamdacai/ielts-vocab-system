<!-- 个人中心页面 -->
<view class="container">
  <!-- 用户信息卡片 -->
  <view class="user-card">
    <view class="user-info">
      <image class="avatar" src="{{user.avatar || '/images/default-avatar.png'}}" mode="aspectFill"></image>
      <view class="user-details">
        <text class="nickname">{{user.nickname || '微信用户'}}</text>
        <view class="user-meta">
          <text class="meta-item">ID: {{user.id}}</text>
          <text class="meta-tag" wx:if="{{user.role === 'admin'}}">管理员</text>
        </view>
      </view>
    </view>
    
    <!-- 统计数据 -->
    <view class="stats-grid">
      <view class="stat-item">
        <text class="stat-value">{{stats.studyDays || 0}}</text>
        <text class="stat-label">学习天数</text>
      </view>
      <view class="stat-item">
        <text class="stat-value">{{stats.totalLearned || 0}}</text>
        <text class="stat-label">累计学习</text>
      </view>
      <view class="stat-item">
        <text class="stat-value">{{stats.masteredWords || 0}}</text>
        <text class="stat-label">已掌握</text>
      </view>
      <view class="stat-item">
        <text class="stat-value">{{stats.streakDays || 0}}</text>
        <text class="stat-label">连续天数</text>
      </view>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-section">
    <view class="menu-item" bindtap="goToSettings">
      <text class="menu-icon">⚙️</text>
      <text class="menu-text">学习设置</text>
      <text class="menu-arrow">></text>
    </view>
    
    <view class="menu-item" bindtap="goToMistakes">
      <text class="menu-icon">📖</text>
      <text class="menu-text">错题本</text>
      <text class="menu-arrow">></text>
    </view>
    
    <view class="menu-item" bindtap="goToAchievements">
      <text class="menu-icon">🏆</text>
      <text class="menu-text">成就系统</text>
      <text class="menu-arrow">></text>
    </view>
    
    <view class="menu-item" wx:if="{{user.role === 'admin'}}" bindtap="goToAdmin">
      <text class="menu-icon">👨‍💼</text>
      <text class="menu-text">管理员后台</text>
      <text class="menu-arrow">></text>
    </view>
    
    <view class="menu-item danger" bindtap="showResetConfirm">
      <text class="menu-icon">🔄</text>
      <text class="menu-text">复位学习进度</text>
      <text class="menu-arrow">></text>
    </view>
  </view>

  <!-- 退出登录按钮 -->
  <view class="logout-section">
    <button class="logout-btn" bindtap="onLogout">退出登录</button>
  </view>

  <!-- 复位确认弹窗 -->
  <view class="modal" wx:if="{{showResetConfirm}}">
    <view class="modal-content">
      <view class="modal-header">
        <text class="modal-title">⚠️ 确认复位学习进度？</text>
      </view>
      
      <view class="modal-body">
        <view class="reset-warning">
          <text>此操作将清空：</text>
          <text class="warning-item">✓ 所有单词学习状态</text>
          <text class="warning-item">✓ 学习记录</text>
          <text class="warning-item">✓ 复习会话</text>
          <text class="warning-item">✓ 发音练习记录</text>
        </view>
        
        <view class="reset-keep">
          <text>不会清空：</text>
          <text class="keep-item">✓ 个人配置</text>
          <text class="keep-item">✓ 账号信息</text>
        </view>
        
        <view class="reason-section">
          <text class="reason-label">复位原因：</text>
          <picker mode="selector" range="{{['重新开始学习', '误操作导致混乱', '其他原因']}}" value="{{resetReasonIndex}}" bindchange="onReasonChange">
            <view class="reason-picker">
              {{['重新开始学习', '误操作导致混乱', '其他原因'][resetReasonIndex || 0]}}
            </view>
          </picker>
        </view>
      </view>
      
      <view class="modal-footer">
        <button class="modal-cancel" bindtap="hideResetConfirm">取消</button>
        <button class="modal-confirm" bindtap="confirmReset">确认复位</button>
      </view>
    </view>
  </view>

  <!-- 加载状态 -->
  <view class="loading-mask" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>
</view>
