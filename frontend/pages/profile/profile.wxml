<!--pages/profile/profile.wxml-->
<view class="profile-container">
  <!-- 用户信息卡片 -->
  <view class="user-card">
    <view class="user-avatar">
      <image wx:if="{{userInfo.avatar}}" src="{{userInfo.avatar}}" mode="aspectFill"></image>
      <view wx:else class="avatar-placeholder">👤</view>
    </view>
    <view class="user-info">
      <view class="user-nickname">{{userInfo.nickname || '微信用户'}}</view>
      <view class="user-id">ID: {{userInfo.id}}</view>
    </view>
    <view class="user-role-tag" wx:if="{{userInfo.role === 'admin'}}">管理员</view>
  </view>

  <!-- 学习统计 -->
  <view class="stats-card">
    <view class="card-title">📊 学习统计</view>
    <view class="stats-grid">
      <view class="stat-item">
        <view class="stat-value">{{userInfo.studyDays}}</view>
        <view class="stat-label">学习天数</view>
      </view>
      <view class="stat-item">
        <view class="stat-value">{{userInfo.totalWords}}</view>
        <view class="stat-label">累计单词</view>
      </view>
      <view class="stat-item">
        <view class="stat-value">{{stats.masteredWords || 0}}</view>
        <view class="stat-label">已掌握</view>
      </view>
      <view class="stat-item">
        <view class="stat-value">{{stats.practiceCount || 0}}</view>
        <view class="stat-label">发音练习</view>
      </view>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-card">
    <view class="menu-item" bindtap="goToReset">
      <view class="menu-icon">🔄</view>
      <view class="menu-text">学习进度复位</view>
      <view class="menu-arrow">›</view>
    </view>
    <view class="menu-item" bindtap="goToPronunciation">
      <view class="menu-icon">🎤</view>
      <view class="menu-text">发音练习</view>
      <view class="menu-arrow">›</view>
    </view>
    <view class="menu-item" bindtap="goToAchievements">
      <view class="menu-icon">🏆</view>
      <view class="menu-text">成就系统</view>
      <view class="menu-arrow">›</view>
    </view>
    <view class="menu-item" wx:if="{{userInfo.role === 'admin'}}" bindtap="goToAdmin">
      <view class="menu-icon">⚙️</view>
      <view class="menu-text">管理员后台</view>
      <view class="menu-arrow">›</view>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="action-buttons">
    <button class="logout-button" bindtap="handleLogout">
      退出登录
    </button>
  </view>

  <!-- 复位确认弹窗 -->
  <view wx:if="{{showResetModal}}" class="modal-overlay" bindtap="closeResetModal">
    <view class="modal-content" catchtap>
      <view class="modal-icon">⚠️</view>
      <view class="modal-title">确认复位学习进度？</view>
      <view class="modal-subtitle">此操作将清空：</view>
      <view class="modal-list">
        <view class="list-item">✓ 所有单词学习状态</view>
        <view class="list-item">✓ 学习记录</view>
        <view class="list-item">✓ 复习会话</view>
        <view class="list-item">✓ 发音练习记录</view>
      </view>
      <view class="modal-keep">
        <view class="keep-title">不会清空：</view>
        <view class="keep-item">✓ 个人配置</view>
        <view class="keep-item">✓ 账号信息</view>
      </view>
      
      <view class="reset-reason">
        <view class="reason-label">复位原因：</view>
        <picker mode="selector" range="{{resetReasons}}" value="{{reasonIndex}}" bindchange="selectReason">
          <view class="reason-picker">{{resetReasons[reasonIndex]}}</view>
        </picker>
      </view>
      
      <view class="modal-actions">
        <button class="cancel-button" bindtap="closeResetModal">取消</button>
        <button class="confirm-button" bindtap="confirmReset" loading="{{resetLoading}}">确认复位</button>
      </view>
    </view>
  </view>
</view>
