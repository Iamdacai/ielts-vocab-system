/* 个人中心页面样式 */

.container {
  min-height: 100vh;
  background: #f5f6f7;
  padding-bottom: 40rpx;
}

/* 用户信息卡片 */
.user-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 40rpx;
  border-radius: 0 0 40rpx 40rpx;
  margin-bottom: 30rpx;
}

.user-info {
  display: flex;
  align-items: center;
  margin-bottom: 40rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  margin-right: 24rpx;
}

.user-details {
  flex: 1;
}

.nickname {
  font-size: 36rpx;
  font-weight: bold;
  color: #ffffff;
  display: block;
  margin-bottom: 12rpx;
}

.user-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.meta-item {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.meta-tag {
  background: rgba(255, 255, 255, 0.2);
  color: #ffffff;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
}

/* 统计数据网格 */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
}

.stat-item {
  background: rgba(255, 255, 255, 0.15);
  border-radius: 20rpx;
  padding: 20rpx 10rpx;
  text-align: center;
  backdrop-filter: blur(10rpx);
}

.stat-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #ffffff;
  display: block;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 功能菜单 */
.menu-section {
  background: #ffffff;
  margin: 0 30rpx 30rpx;
  border-radius: 20rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 32rpx 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item.danger {
  color: #ff4d4f;
}

.menu-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: #333333;
}

.menu-item.danger .menu-text {
  color: #ff4d4f;
}

.menu-arrow {
  color: #cccccc;
  font-size: 28rpx;
}

/* 退出登录区域 */
.logout-section {
  margin: 0 30rpx;
}

.logout-btn {
  background: #ffffff;
  color: #ff4d4f;
  font-size: 30rpx;
  border-radius: 20rpx;
  padding: 28rpx 0;
  border: 2rpx solid #ff4d4f;
}

/* 弹窗样式 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  background: #ffffff;
  width: 90%;
  max-width: 600rpx;
  border-radius: 24rpx;
  overflow: hidden;
}

.modal-header {
  padding: 32rpx 24rpx 16rpx;
  text-align: center;
}

.modal-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333333;
}

.modal-body {
  padding: 0 24rpx 24rpx;
}

.reset-warning, .reset-keep {
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.reset-warning {
  background: #fff3e0;
}

.warning-item, .keep-item {
  display: block;
  font-size: 26rpx;
  color: #666666;
  margin-top: 8rpx;
}

.warning-item {
  color: #ff9800;
}

.reason-section {
  margin-top: 24rpx;
}

.reason-label {
  display: block;
  font-size: 28rpx;
  color: #333333;
  margin-bottom: 12rpx;
}

.reason-picker {
  background: #f5f6f7;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #333333;
}

.modal-footer {
  display: flex;
  border-top: 1rpx solid #f0f0f0;
}

.modal-cancel, .modal-confirm {
  flex: 1;
  padding: 28rpx 0;
  font-size: 30rpx;
  border: none;
  border-radius: 0;
}

.modal-cancel {
  background: #f5f6f7;
  color: #666666;
}

.modal-confirm {
  background: #ff4d4f;
  color: #ffffff;
}

/* 加载遮罩 */
.loading-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255, 255, 255, 0.9);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #666666;
  z-index: 999;
}
