/* pages/profile/profile.wxss */
.profile-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 20rpx;
}

/* 用户信息卡片 */
.user-card {
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  border-radius: 20rpx;
  padding: 40rpx;
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(24, 144, 255, 0.3);
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  overflow: hidden;
  margin-right: 30rpx;
}

.user-avatar image {
  width: 100%;
  height: 100%;
}

.avatar-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
  color: #ffffff;
}

.user-info {
  flex: 1;
}

.user-nickname {
  font-size: 36rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 10rpx;
}

.user-id {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

.user-role-tag {
  background: rgba(255, 255, 255, 0.2);
  color: #ffffff;
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
  font-size: 22rpx;
}

/* 统计卡片 */
.stats-card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.card-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 25rpx;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
}

.stat-item {
  text-align: center;
}

.stat-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #1890ff;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 22rpx;
  color: #999999;
}

/* 功能菜单 */
.menu-card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 0 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: #333333;
}

.menu-arrow {
  font-size: 40rpx;
  color: #cccccc;
}

/* 操作按钮 */
.action-buttons {
  padding: 20rpx;
}

.logout-button {
  background: #ffffff;
  color: #ff4d4f;
  border: 2rpx solid #ff4d4f;
  border-radius: 50rpx;
  padding: 28rpx;
  font-size: 32rpx;
}

.logout-button:active {
  background: #ff4d4f;
  color: #ffffff;
}

/* 复位确认弹窗 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 40rpx;
  width: 85%;
  max-width: 600rpx;
}

.modal-icon {
  font-size: 80rpx;
  text-align: center;
  margin-bottom: 20rpx;
}

.modal-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
  text-align: center;
  margin-bottom: 15rpx;
}

.modal-subtitle {
  font-size: 26rpx;
  color: #666666;
  text-align: center;
  margin-bottom: 20rpx;
}

.modal-list {
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.list-item {
  font-size: 24rpx;
  color: #ff4d4f;
  margin-bottom: 8rpx;
}

.list-item:last-child {
  margin-bottom: 0;
}

.modal-keep {
  background: #f0f9ff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.keep-title {
  font-size: 24rpx;
  color: #1890ff;
  margin-bottom: 10rpx;
}

.keep-item {
  font-size: 24rpx;
  color: #1890ff;
  margin-bottom: 8rpx;
}

.reset-reason {
  margin-bottom: 30rpx;
}

.reason-label {
  font-size: 26rpx;
  color: #666666;
  margin-bottom: 15rpx;
}

.reason-picker {
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  color: #333333;
}

.modal-actions {
  display: flex;
  gap: 20rpx;
}

.cancel-button {
  flex: 1;
  background: #f5f5f5;
  color: #666666;
  border: none;
  border-radius: 50rpx;
  padding: 24rpx;
  font-size: 30rpx;
}

.confirm-button {
  flex: 1;
  background: linear-gradient(135deg, #ff4d4f 0%, #ff7875 100%);
  color: #ffffff;
  border: none;
  border-radius: 50rpx;
  padding: 24rpx;
  font-size: 30rpx;
}
