/* pages/admin/index.wxss */
.admin-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 20rpx;
}

/* 统计卡片 */
.stats-card {
  background: linear-gradient(135deg, #722ed1 0%, #531dab 100%);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(114, 46, 209, 0.3);
}

.card-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 25rpx;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
}

.stat-item {
  text-align: center;
}

.stat-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 用户列表卡片 */
.users-card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.card-header .card-title {
  color: #333333;
  margin-bottom: 0;
}

.refresh-btn {
  font-size: 36rpx;
  cursor: pointer;
}

.loading-text {
  text-align: center;
  padding: 40rpx;
  color: #999999;
}

.user-list {
  max-height: 600rpx;
  overflow-y: auto;
}

.user-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.user-item:last-child {
  border-bottom: none;
}

.user-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.user-avatar-small {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #f5f5f5;
  overflow: hidden;
  margin-right: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}

.user-avatar-small image {
  width: 100%;
  height: 100%;
}

.user-detail {
  flex: 1;
}

.user-name {
  font-size: 28rpx;
  color: #333333;
  margin-bottom: 8rpx;
}

.user-meta {
  display: flex;
  gap: 10rpx;
}

.role-tag {
  background: #722ed1;
  color: #ffffff;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  font-size: 20rpx;
}

.status-tag {
  background: #52c41a;
  color: #ffffff;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  font-size: 20rpx;
}

.status-tag.banned {
  background: #ff4d4f;
}

.user-stats {
  display: flex;
  gap: 30rpx;
}

.user-stat {
  text-align: center;
}

.stat-num {
  font-size: 28rpx;
  font-weight: bold;
  color: #1890ff;
}

.stat-unit {
  font-size: 22rpx;
  color: #999999;
  margin-left: 4rpx;
}

.load-more {
  text-align: center;
  padding: 20rpx;
  color: #1890ff;
  font-size: 26rpx;
}

/* 管理员操作 */
.admin-actions {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.action-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 20rpx;
}

.action-button {
  width: 100%;
  background: #722ed1;
  color: #ffffff;
  border: none;
  border-radius: 50rpx;
  padding: 24rpx;
  font-size: 28rpx;
  margin-bottom: 15rpx;
}

.action-button.warning {
  background: #faad14;
}

.action-button:active {
  opacity: 0.8;
}

/* 弹窗 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 40rpx;
  width: 85%;
  max-width: 500rpx;
}

.modal-icon {
  font-size: 80rpx;
  text-align: center;
  margin-bottom: 20rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  text-align: center;
  margin-bottom: 15rpx;
}

.modal-warning {
  font-size: 26rpx;
  color: #ff4d4f;
  text-align: center;
  margin-bottom: 30rpx;
  padding: 20rpx;
  background: #fff1f0;
  border-radius: 12rpx;
}

.modal-actions {
  display: flex;
  gap: 20rpx;
}

.cancel-button {
  flex: 1;
  background: #f5f5f5;
  color: #666666;
  border: none;
  border-radius: 50rpx;
  padding: 24rpx;
  font-size: 28rpx;
}

.confirm-button {
  flex: 1;
  background: linear-gradient(135deg, #ff4d4f 0%, #ff7875 100%);
  color: #ffffff;
  border: none;
  border-radius: 50rpx;
  padding: 24rpx;
  font-size: 28rpx;
}

.confirm-button.danger {
  background: linear-gradient(135deg, #ff4d4f 0%, #d9363e 100%);
}
