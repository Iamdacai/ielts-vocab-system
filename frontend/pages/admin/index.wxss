/* 管理员后台样式 */

.container {
  min-height: 100vh;
  background: #f5f6f7;
}

/* 标签页 */
.tabs {
  display: flex;
  background: #ffffff;
  border-bottom: 1rpx solid #e5e5e5;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 28rpx 0;
  font-size: 30rpx;
  color: #666666;
  position: relative;
}

.tab-item.active {
  color: #667eea;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background: #667eea;
  border-radius: 2rpx;
}

/* 面板 */
.panel {
  padding: 24rpx;
}

/* 统计网格 */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.stat-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx 20rpx;
  text-align: center;
}

.stat-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #667eea;
  display: block;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #999999;
}

/* 排行榜 */
.top-users {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 20rpx;
}

.user-list {
  display: flex;
  flex-direction: column;
}

.user-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.user-item:last-child {
  border-bottom: none;
}

.rank {
  width: 40rpx;
  height: 40rpx;
  background: #f0f0f0;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: bold;
  color: #666666;
  margin-right: 16rpx;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 16rpx;
}

.user-info {
  flex: 1;
}

.nickname-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.nickname {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
}

.tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
}

.tag-admin {
  background: #667eea;
  color: #ffffff;
}

.tag-banned {
  background: #ff4d4f;
  color: #ffffff;
}

.meta {
  font-size: 24rpx;
  color: #999999;
}

/* 操作按钮 */
.actions {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.action-btn {
  font-size: 22rpx;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  background: #667eea;
  color: #ffffff;
  border: none;
}

.action-btn.danger {
  background: #ff4d4f;
}

.action-btn.success {
  background: #52c41a;
}

.action-btn.warn {
  background: #ff9800;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 30rpx;
  color: #999999;
  font-size: 26rpx;
}

/* 弹窗 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  background: #ffffff;
  width: 80%;
  max-width: 500rpx;
  border-radius: 24rpx;
  overflow: hidden;
}

.modal-header {
  padding: 32rpx 24rpx 16rpx;
  text-align: center;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.modal-body {
  padding: 0 24rpx 32rpx;
  text-align: center;
  font-size: 28rpx;
  color: #666666;
}

.modal-footer {
  display: flex;
  border-top: 1rpx solid #f0f0f0;
}

.modal-cancel, .modal-confirm {
  flex: 1;
  padding: 28rpx 0;
  font-size: 30rpx;
  border: none;
  border-radius: 0;
}

.modal-cancel {
  background: #f5f6f7;
  color: #666666;
}

.modal-confirm {
  background: #ff4d4f;
  color: #ffffff;
}
