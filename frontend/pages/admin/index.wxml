<!--pages/admin/index.wxml-->
<view class="admin-container">
  <!-- 全局统计 -->
  <view class="stats-card">
    <view class="card-title">📊 全局统计</view>
    <view class="stats-grid">
      <view class="stat-item">
        <view class="stat-value">{{stats.totalUsers}}</view>
        <view class="stat-label">总用户数</view>
      </view>
      <view class="stat-item">
        <view class="stat-value">{{stats.activeUsers}}</view>
        <view class="stat-label">活跃用户</view>
      </view>
      <view class="stat-item">
        <view class="stat-value">{{stats.totalWordsLearned}}</view>
        <view class="stat-label">学习单词</view>
      </view>
      <view class="stat-item">
        <view class="stat-value">{{stats.newUsersToday}}</view>
        <view class="stat-label">今日新增</view>
      </view>
    </view>
  </view>

  <!-- 用户列表 -->
  <view class="users-card">
    <view class="card-header">
      <view class="card-title">👥 用户列表</view>
      <view class="refresh-btn" bindtap="loadUsers">🔄</view>
    </view>
    
    <view wx:if="{{loading}}" class="loading-text">加载中...</view>
    
    <view wx:else class="user-list">
      <view wx:for="{{users}}" wx:key="id" class="user-item">
        <view class="user-left">
          <view class="user-avatar-small">
            <image wx:if="{{item.avatar_url}}" src="{{item.avatar_url}}" mode="aspectFill"></image>
            <view wx:else>👤</view>
          </view>
          <view class="user-detail">
            <view class="user-name">{{item.nickname || '微信用户'}}</view>
            <view class="user-meta">
              <text class="role-tag" wx:if="{{item.role === 'admin'}}">管理员</text>
              <text class="status-tag" wx:if="{{item.status === 'active'}}">正常</text>
              <text class="status-tag banned" wx:if="{{item.status === 'banned'}}">封禁</text>
            </view>
          </view>
        </view>
        <view class="user-stats">
          <view class="user-stat">
            <text class="stat-num">{{item.studyDays}}</text>
            <text class="stat-unit">天</text>
          </view>
          <view class="user-stat">
            <text class="stat-num">{{item.totalWords}}</text>
            <text class="stat-unit">词</text>
          </view>
        </view>
      </view>
    </view>
    
    <!-- 加载更多 -->
    <view wx:if="{{hasMore}}" class="load-more" bindtap="loadMore">
      加载更多
    </view>
  </view>

  <!-- 管理员操作 -->
  <view class="admin-actions">
    <view class="action-title">⚙️ 管理操作</view>
    <button class="action-button" bindtap="showResetAllModal">
      🔄 复位全部用户数据
    </button>
    <button class="action-button warning" bindtap="viewSystemLogs">
      📋 查看系统日志
    </button>
  </view>

  <!-- 复位全部用户确认弹窗 -->
  <view wx:if="{{showResetAllModal}}" class="modal-overlay" bindtap="closeResetAllModal">
    <view class="modal-content" catchtap="true">
      <view class="modal-icon">⚠️</view>
      <view class="modal-title">确认复位全部用户数据？</view>
      <view class="modal-warning">此操作将清空所有用户的学习进度，且不可恢复！</view>
      <view class="modal-actions">
        <button class="cancel-button" bindtap="closeResetAllModal">取消</button>
        <button class="confirm-button danger" bindtap="confirmResetAll" loading="{{resetLoading}}">确认复位</button>
      </view>
    </view>
  </view>
</view>
