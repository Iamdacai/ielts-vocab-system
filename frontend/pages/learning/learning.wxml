<!--pages/learning/learning.wxml - 学时确认优化版-->
<view class="container">
  <!-- 顶部进度 -->
  <view class="header">
    <view class="progress-info">
      <text class="progress-text">🟢 学习新词</text>
      <text class="progress-count">{{currentIndex + 1}} / {{totalWords}}</text>
    </view>
    <view class="progress-bar">
      <view class="progress-fill" style="width: {{progress}}%"></view>
    </view>
  </view>

  <!-- 单词卡片 -->
  <view wx:if="{{currentWord}}" class="word-card">
    <view class="word-header">
      <view class="word-main">
        <view class="word-text">{{currentWord.word}}</view>
        <!-- 🆕 音标显示（从词库取，没有则隐藏） -->
        <view wx:if="{{currentWord.phonetic}}" class="word-phonetic">/{{currentWord.phonetic}}/</view>
      </view>
      
      <!-- 🆕 单词发音按钮（小喇叭图标） -->
      <view class="word-audio-icon" bindtap="playWordAudio" hover-class="icon-hover">
        🔊
      </view>
    </view>
    
    <!-- 🆕 发音练习按钮 -->
    <view class="pronunciation-practice">
      <button class="practice-button" bindtap="startPronunciationPractice">
        🎤 跟读练习
      </button>
      <view wx:if="{{isRecording}}" class="recording-status">
        <view class="recording-indicator"></view>
        <text>正在录音... {{recordingTime}}s</text>
      </view>
      <view wx:if="{{pronunciationResult}}" class="pronunciation-result">
        <view class="score-display">
          <text class="score-number">{{pronunciationResult.score}}</text>
          <text class="score-label">分</text>
        </view>
        <view class="feedback-text">{{pronunciationResult.feedback}}</view>
        <view class="score-details" wx:if="{{pronunciationResult.accuracy}}">
          <text>准确度：{{pronunciationResult.accuracy}}</text>
          <text wx:if="{{pronunciationResult.fluency}}"> | 流利度：{{pronunciationResult.fluency}}</text>
        </view>
        <!-- 🆕 播放录音功能 -->
        <view wx:if="{{pronunciationResult.audioPath}}" class="audio-playback">
          <button class="play-audio-button" bindtap="playMyPronunciation">
            🔊 播放我的录音
          </button>
        </view>
        <view class="result-actions">
          <button class="retry-button" bindtap="startPronunciationPractice">
            🔄 重新录制
          </button>
          <button class="history-button" bindtap="goToPronunciationHistory">
            📊 历史记录
          </button>
        </view>
      </view>
    </view>

    <!-- 🆕 词库和分类信息 -->
    <view wx:if="{{currentWord.source}}" class="word-source">
      <text class="source-tag">{{currentWord.source}}</text>
      <text wx:if="{{currentWord.category}}" class="category-tag">{{currentWord.categoryName}}</text>
    </view>

    <!-- 短语标记 -->
    <view wx:if="{{currentWord.is_phrase}}" class="phrase-badge">
      📝 短语
    </view>

    <!-- 释义 -->
    <view class="translation-section">
      <view class="translation-title">📖 释义</view>
      <!-- 🆕 中文释义（从词库取） -->
      <view wx:if="{{currentWord.translation_cn}}" class="translation-cn">{{currentWord.translation_cn}}</view>
      <!-- 🆕 英文释义（从词库取） -->
      <view wx:if="{{currentWord.translation}}" class="translation-text">{{currentWord.translation}}</view>
      <view wx:if="{{currentWord.pos}}" class="pos-tag">{{currentWord.pos}}</view>
    </view>

    <!-- 例句（显示全部例句） -->
    <view wx:if="{{currentWord.examples && currentWord.examples.length > 0}}" class="example-section">
      <view class="example-header">
        <view class="example-title">💬 例句</view>
        <!-- 🆕 例句发音按钮（小喇叭图标） -->
        <view class="example-audio-icon" bindtap="playExampleAudio" hover-class="icon-hover">
          🔊
        </view>
      </view>
      <view wx:for="{{currentWord.examples}}" wx:key="*this" class="example-item">
        <view class="example-text">{{item}}</view>
      </view>
    </view>

    <!-- 同义替换 -->
    <view wx:if="{{currentWord.synonyms && currentWord.synonyms.length > 0}}" class="synonyms-section">
      <view class="synonyms-title">📚 同义替换</view>
      <view class="synonyms-list">
        <block wx:for="{{currentWord.synonyms}}" wx:key="*this">
          <view class="synonym-item">{{item}}</view>
        </block>
      </view>
    </view>

    <!-- 词根词缀 -->
    <view wx:if="{{currentWord.etymology}}" class="etymology-section">
      <view class="etymology-title">🌳 词根词缀</view>
      <view class="etymology-text">{{currentWord.etymology}}</view>
    </view>
  </view>

  <!-- 学习判断按钮 -->
  <view class="learning-actions">
    <view class="action-buttons">
      <button class="action-button forgot" bindtap="handleForgot">
        ✗ 忘记
      </button>
      <button class="action-button hard" bindtap="handleHard">
        😅 困难
      </button>
      <button class="action-button know" bindtap="handleKnow">
        ✓ 认识
      </button>
    </view>
    
    <view class="hint-text">
      💡 根据掌握程度选择，系统会智能安排复习
    </view>
  </view>

  <!-- 学时确认弹窗 -->
  <view wx:if="{{showDurationModal}}" class="modal-overlay">
    <view class="modal-content">
      <view class="modal-icon">⏰</view>
      <view class="modal-title">学习时间确认</view>
      <view class="modal-subtitle">培养时间意识，累积成就感</view>
      
      <!-- 时间显示 -->
      <view class="duration-display">
        <view class="duration-label">本次学习时长</view>
        <view class="duration-time">{{formattedDuration}}</view>
        <view class="duration-words">
          <text>新学：{{sessionStats.newWords}}词</text>
          <text class="divider">|</text>
          <text>复习：{{sessionStats.reviewWords}}词</text>
        </view>
      </view>
      
      <!-- 快捷选项 -->
      <view class="quick-options">
        <view class="quick-options-title">快速选择</view>
        <view class="quick-buttons">
          <button 
            class="quick-button {{confirmedDuration === 15 ? 'active' : ''}}" 
            bindtap="setDuration" 
            data-minutes="15">15 分钟</button>
          <button 
            class="quick-button {{confirmedDuration === 30 ? 'active' : ''}}" 
            bindtap="setDuration" 
            data-minutes="30">30 分钟</button>
          <button 
            class="quick-button {{confirmedDuration === 45 ? 'active' : ''}}" 
            bindtap="setDuration" 
            data-minutes="45">45 分钟</button>
          <button 
            class="quick-button {{confirmedDuration === 60 ? 'active' : ''}}" 
            bindtap="setDuration" 
            data-minutes="60">60 分钟</button>
        </view>
      </view>
      
      <!-- 操作按钮 -->
      <view class="modal-actions">
        <button class="confirm-button" bindtap="confirmDuration">
          ✓ 确认提交
        </button>
        <button class="skip-button" bindtap="skipDuration">
          跳过
        </button>
      </view>
      
      <view class="modal-hint">
        💡 准确记录学习时长有助于生成精准的学习报告
      </view>
    </view>
  </view>

  <!-- 完成提示 -->
  <view wx:if="{{showComplete}}" class="complete-modal">
    <view class="complete-content">
      <view class="complete-icon">🎉</view>
      <view class="complete-title">学习完成！</view>
      <view class="complete-stats">
        <view class="complete-stat">
          <view class="stat-value">{{sessionStats.newWords}}</view>
          <view class="stat-label">新学单词</view>
        </view>
        <view class="complete-stat">
          <view class="stat-value success-color">{{sessionStats.masteredWords}}</view>
          <view class="stat-label">已掌握</view>
        </view>
      </view>
      <view class="complete-time">
        学习时长：{{formattedDuration}}
      </view>
      
      <!-- 🆕 操作按钮 -->
      <view class="complete-actions">
        <button class="continue-button" bindtap="continueLearning">
          📚 继续学习
        </button>
        <button class="finish-button" bindtap="finishLearning">
          ✓ 结束学习
        </button>
      </view>
    </view>
  </view>
</view>
