/* pages/learning/learning.wxss */

/* 容器 */
.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.learning-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
}

/* 加载状态 */
.loading-container {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  height: 100vh;
}

.loading-text {
  color: #fff;
  font-size: 32rpx;
  margin-top: 20rpx;
}

/* 进度条区域 */
.progress-section {
  padding: 20rpx;
  background: rgba(255, 255, 255, 0.95);
}

.progress-bar {
  width: 100%;
  height: 8rpx;
}

.progress-text {
  text-align: right;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #666;
}

/* 单词显示区域 */
.word-section {
  flex: 1;
  padding: 40rpx 30rpx;
  background: #fff;
  margin: 20rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
}

/* 英文单词区域 */
.english-section {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.english-word {
  font-size: 56rpx;
  font-weight: bold;
  color: #333;
  flex: 1;
}

.pronunciation-btn {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  justify-content: center;
  align-items: center;
  margin-left: 20rpx;
  border: none;
  padding: 0;
}

.pronunciation-btn.playing {
  animation: pulse 1s infinite;
}

.btn-icon {
  font-size: 40rpx;
}

.btn-icon-large {
  font-size: 48rpx;
  margin-right: 10rpx;
}

/* 中文释义区域 */
.chinese-section {
  background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
  padding: 30rpx;
  border-radius: 16rpx;
  margin-bottom: 30rpx;
}

.chinese-meaning {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 16rpx;
}

.phonetic-section {
  margin-top: 10rpx;
}

.phonetic {
  font-size: 26rpx;
  color: #666;
  font-style: italic;
}

/* 发音练习区域 */
.pronunciation-practice-section {
  margin-top: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.practice-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}

.record-btn {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  color: #fff;
  border: none;
  border-radius: 50rpx;
  padding: 24rpx 48rpx;
  font-size: 30rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 20rpx rgba(245, 87, 108, 0.4);
  margin-bottom: 20rpx;
}

.record-btn.recording {
  background: linear-gradient(135deg, #ff6b6b 0%, #c92a2a 100%);
  animation: recording-pulse 1s infinite;
}

.record-btn:disabled {
  background: #ccc;
  box-shadow: none;
}

.btn-text {
  color: #fff;
}

.stop-record-btn {
  background: #fff;
  color: #f5576c;
  border: 2rpx solid #f5576c;
  border-radius: 50rpx;
  padding: 16rpx 32rpx;
  font-size: 26rpx;
  margin-bottom: 20rpx;
}

.permission-tip {
  background: #fff3cd;
  border: 1rpx solid #ffc107;
  border-radius: 12rpx;
  padding: 16rpx 24rpx;
  margin-bottom: 20rpx;
}

.permission-tip text {
  color: #856404;
  font-size: 24rpx;
}

/* 评分结果显示 */
.score-section {
  margin-top: 20rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, #d4fc79 0%, #96e6a1 100%);
  border-radius: 16rpx;
  width: 100%;
  animation: slide-up 0.3s ease-out;
}

.score-display {
  text-align: center;
  margin-bottom: 12rpx;
}

.score-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #2d6a4f;
}

.feedback {
  text-align: center;
}

.feedback text {
  font-size: 26rpx;
  color: #40916c;
}

/* 答案切换按钮 */
.answer-toggle-section {
  padding: 0 30rpx;
  margin-bottom: 20rpx;
}

.toggle-btn {
  background: rgba(255, 255, 255, 0.9);
  color: #333;
  border: none;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  width: 100%;
}

/* 操作按钮区域 */
.action-section {
  display: flex;
  align-items: center;
  padding: 30rpx 20rpx;
  background: rgba(255, 255, 255, 0.95);
  gap: 20rpx;
}

.nav-btn {
  width: 120rpx;
  border-radius: 12rpx;
  padding: 20rpx 0;
  font-size: 26rpx;
  font-weight: 600;
}

.prev-btn, .next-btn {
  background: #e9ecef;
  color: #495057;
}

.prev-btn:disabled, .next-btn:disabled {
  background: #dee2e6;
  color: #adb5bd;
}

.mastery-section {
  flex: 1;
  display: flex;
  gap: 12rpx;
}

.mastery-btn {
  flex: 1;
  border-radius: 12rpx;
  padding: 20rpx 0;
  font-size: 24rpx;
  font-weight: 600;
  border: none;
}

.know-btn {
  background: linear-gradient(135deg, #56ab2f 0%, #a8e063 100%);
  color: #fff;
}

.hard-btn {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  color: #fff;
}

.forgot-btn {
  background: linear-gradient(135deg, #fa709a 0%, #fee140 100%);
  color: #fff;
}

/* 动画 */
@keyframes pulse {
  0%, 100% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.1);
  }
}

@keyframes recording-pulse {
  0%, 100% {
    box-shadow: 0 8rpx 20rpx rgba(245, 87, 108, 0.4);
  }
  50% {
    box-shadow: 0 8rpx 40rpx rgba(245, 87, 108, 0.8);
  }
}

@keyframes slide-up {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}
