/* pages/learning/learning.wxss - 学时确认优化版 */
.container {
  padding: 20rpx;
  background: linear-gradient(180deg, #1f2937 0%, #111827 100%);
  min-height: 100vh;
}

/* 头部进度 */
.header {
  margin-bottom: 30rpx;
}

.progress-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.progress-text {
  font-size: 28rpx;
  color: #22c55e;
  font-weight: bold;
}

.progress-count {
  font-size: 24rpx;
  color: #9ca3af;
}

.progress-bar {
  width: 100%;
  height: 12rpx;
  background: #374151;
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #22c55e 0%, #16a34a 100%);
  transition: width 0.3s ease;
}

/* 单词卡片 */
.word-card {
  background: #1f2937;
  border-radius: 20rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.3);
}

.word-header {
  text-align: center;
  margin-bottom: 30rpx;
  position: relative;
}

.word-text {
  font-size: 48rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 10rpx;
}

.word-phonetic {
  font-size: 28rpx;
  color: #9ca3af;
  font-family: monospace;
}

/* 🆕 播放按钮 */
.audio-play-btn {
  position: absolute;
  right: 0;
  top: 50%;
  transform: translateY(-50%);
  font-size: 40rpx;
  cursor: pointer;
  padding: 10rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.audio-play-btn:active {
  background: rgba(255, 255, 255, 0.2);
}

/* 🆕 词库和分类标签 */
.word-source {
  display: flex;
  justify-content: center;
  gap: 15rpx;
  margin-bottom: 20rpx;
}

.source-tag {
  font-size: 22rpx;
  color: #60a5fa;
  background: rgba(96, 165, 250, 0.1);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.category-tag {
  font-size: 22rpx;
  color: #34d399;
  background: rgba(52, 211, 153, 0.1);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.phrase-badge {
  display: inline-block;
  background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
  color: white;
  padding: 8rpx 24rpx;
  border-radius: 50rpx;
  font-size: 24rpx;
  margin-bottom: 20rpx;
}

/* 释义区域 */
.translation-section {
  background: #111827;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.translation-title {
  font-size: 24rpx;
  color: #9ca3af;
  margin-bottom: 10rpx;
}

.translation-text {
  font-size: 32rpx;
  color: #22c55e;
  font-weight: bold;
}

/* 例句区域 */
.example-section {
  background: #111827;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.example-title {
  font-size: 24rpx;
  color: #9ca3af;
  margin-bottom: 10rpx;
}

.example-text {
  font-size: 28rpx;
  color: #ffffff;
  line-height: 1.6;
  margin-bottom: 10rpx;
}

.example-translation {
  font-size: 26rpx;
  color: #9ca3af;
  line-height: 1.5;
}

.audio-buttons {
  display: flex;
  gap: 20rpx;
  margin-top: 20rpx;
}

.audio-button {
  flex: 1;
  background: #374151;
  color: white;
  border: none;
  border-radius: 12rpx;
  padding: 16rpx;
  font-size: 24rpx;
}

/* 同义替换 */
.synonyms-section {
  background: #111827;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.synonyms-title {
  font-size: 24rpx;
  color: #9ca3af;
  margin-bottom: 15rpx;
}

.synonyms-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.synonym-item {
  background: #374151;
  color: #60a5fa;
  padding: 10rpx 20rpx;
  border-radius: 50rpx;
  font-size: 24rpx;
}

/* 词根词缀 */
.etymology-section {
  background: #111827;
  border-radius: 16rpx;
  padding: 24rpx;
}

.etymology-title {
  font-size: 24rpx;
  color: #9ca3af;
  margin-bottom: 10rpx;
}

.etymology-text {
  font-size: 26rpx;
  color: #d1d5db;
  line-height: 1.6;
}

/* 学习判断按钮 */
.learning-actions {
  margin-bottom: 30rpx;
}

.action-buttons {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.action-button {
  flex: 1;
  border: none;
  border-radius: 20rpx;
  padding: 30rpx;
  font-size: 32rpx;
  font-weight: bold;
}

.action-button.forgot {
  background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
  color: white;
}

.action-button.hard {
  background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
  color: white;
}

.action-button.know {
  background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%);
  color: white;
}

.hint-text {
  text-align: center;
  font-size: 24rpx;
  color: #9ca3af;
}

/* 学时确认弹窗 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.8);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  background: #1f2937;
  border-radius: 24rpx;
  padding: 50rpx 40rpx;
  width: 85%;
  max-width: 650rpx;
  max-height: 90vh;
  overflow-y: auto;
}

.modal-icon {
  font-size: 80rpx;
  text-align: center;
  margin-bottom: 20rpx;
}

.modal-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #ffffff;
  text-align: center;
  margin-bottom: 10rpx;
}

.modal-subtitle {
  font-size: 26rpx;
  color: #9ca3af;
  text-align: center;
  margin-bottom: 40rpx;
}

/* 时间显示 */
.duration-display {
  background: #111827;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  text-align: center;
}

.duration-label {
  font-size: 26rpx;
  color: #9ca3af;
  margin-bottom: 15rpx;
}

.duration-time {
  font-size: 64rpx;
  font-weight: bold;
  color: #f59e0b;
  font-family: monospace;
  margin-bottom: 15rpx;
}

.duration-words {
  display: flex;
  justify-content: center;
  gap: 20rpx;
  font-size: 26rpx;
  color: #d1d5db;
}

.duration-words .divider {
  color: #6b7280;
}

/* 快捷选项 */
.quick-options {
  margin-bottom: 30rpx;
}

.quick-options-title {
  font-size: 26rpx;
  color: #9ca3af;
  text-align: center;
  margin-bottom: 15rpx;
}

.quick-buttons {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 15rpx;
}

.quick-button {
  background: #374151;
  color: #d1d5db;
  border: none;
  border-radius: 12rpx;
  padding: 20rpx 10rpx;
  font-size: 24rpx;
}

.quick-button.active {
  background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
  color: white;
}

/* 操作按钮 */
.modal-actions {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
  margin-bottom: 20rpx;
}

.confirm-button {
  background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
  color: white;
  border: none;
  border-radius: 50rpx;
  padding: 28rpx;
  font-size: 32rpx;
  font-weight: bold;
}

.skip-button {
  background: transparent;
  color: #9ca3af;
  border: 2rpx solid #374151;
  border-radius: 50rpx;
  padding: 20rpx;
  font-size: 28rpx;
}

.modal-hint {
  text-align: center;
  font-size: 22rpx;
  color: #6b7280;
}

/* 完成提示 */
.complete-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.8);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.complete-content {
  background: #1f2937;
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  width: 80%;
  max-width: 600rpx;
  text-align: center;
}

.complete-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.complete-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 40rpx;
}

.complete-stats {
  display: flex;
  justify-content: space-around;
  margin-bottom: 30rpx;
}

.complete-stat {
  text-align: center;
}

.stat-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #9ca3af;
}

.success-color {
  color: #22c55e !important;
}

.complete-time {
  font-size: 28rpx;
  color: #f59e0b;
  font-weight: bold;
}
