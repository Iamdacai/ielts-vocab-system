# 雅思背单词系统环境变量配置示例
# 完整配置请参考 AI_CONFIG.md

# 服务器配置
PORT=3001
NODE_ENV=production

# ⭐ MiniMax AI 配置（核心 AI 服务）
# 用于：AI 例句、写作批改、口语评分、阅读解析、听力诊断、学习计划
MINIMAX_API_KEY=sk-your-minimax-api-key-here
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
MINIMAX_MODEL=MiniMax-M2.5  # 可选：M2-her(免费), MiniMax-M2.5, MiniMax-M2.7

# TTS 服务配置（Azure Cognitive Services）
TTS_API_KEY=your-azure-tts-api-key
TTS_REGION=eastasia
TTS_VOICE=en-US-JennyNeural

# 发音评分服务配置（Azure Pronunciation Assessment）
PRONUNCIATION_API_KEY=your-azure-pronunciation-api-key
PRONUNCIATION_REGION=eastasia
PRONUNCIATION_LANGUAGE=en-US

# 数据库配置（SQLite 默认）
DB_PATH=./ielts_vocab.db

# 数据库配置（如果使用 PostgreSQL）
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=ielts_vocab
# DB_USER=your_db_user
# DB_PASSWORD=your_db_password
