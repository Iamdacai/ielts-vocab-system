# ============================================
# 雅思智能背单词系统 - 环境变量配置
# ============================================
# 复制此文件为 .env 并填入实际值
# 注意：.env 文件不应提交到 Git

# --------------------------------------------
# Bailian API 配置（AI 功能必需）
# --------------------------------------------
BAILIAN_API_KEY=your_api_key_here

# 可选：指定模型（默认：qwen-max）
# BAILIAN_MODEL=qwen-max

# --------------------------------------------
# 服务器配置
# --------------------------------------------
PORT=3001
NODE_ENV=production

# --------------------------------------------
# SSL 证书配置（HTTPS 必需）
# --------------------------------------------
SSL_CERT_PATH=/etc/letsencrypt/live/caiyuyang.cn/ielts.crt
SSL_KEY_PATH=/etc/letsencrypt/live/caiyuyang.cn/ielts.key

# --------------------------------------------
# 数据库配置
# --------------------------------------------
DB_PATH=./ielts_vocab.db

# --------------------------------------------
# 其他配置
# --------------------------------------------
# 日志级别：debug, info, warn, error
LOG_LEVEL=info

# 缓存过期时间（秒）
CACHE_TTL=86400
