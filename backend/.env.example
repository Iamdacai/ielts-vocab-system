# ==================== 服务器配置 ====================
PORT=3001
NODE_ENV=development

# ==================== 微信登录配置 ====================
# 微信小程序 AppID（在微信公众平台获取）
WECHAT_APP_ID=your_wechat_appid
# 微信小程序 AppSecret（在微信公众平台获取）
WECHAT_APP_SECRET=your_wechat_app_secret

# ==================== JWT 认证配置 ====================
# JWT 密钥（生产环境请使用强随机字符串）
JWT_SECRET=your_jwt_secret_key_change_in_production
# Token 有效期（默认 7 天）
JWT_EXPIRES_IN=7d

# ==================== 管理员配置 ====================
# 首个管理员的微信 openid（登录一次后从日志中获取）
ADMIN_OPENID=your_admin_openid_here

# ==================== 有道 TTS 配置 ====================
YOUDAO_APP_KEY=your_youdao_app_key
YOUDAO_SECRET_KEY=your_youdao_secret_key

# ==================== 数据库配置 ====================
# SQLite 数据库文件路径（相对路径）
DB_PATH=./scripts/ielts_vocab.db

# ==================== SSL 证书配置 ====================
# HTTPS 证书路径（生产环境）
SSL_CERT_PATH=/etc/letsencrypt/live/caiyuyang.cn/fullchain.pem
SSL_KEY_PATH=/etc/letsencrypt/live/caiyuyang.cn/privkey.pem

# ==================== 系统功能开关 ====================
# 是否启用管理员后台
ENABLE_ADMIN_PANEL=true
# 是否启用用户学习进度复位
ENABLE_USER_RESET=true
