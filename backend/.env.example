# ==================== 微信登录配置 ====================
# ⚠️ 以下配置必须填写，否则微信登录功能无法使用
# 在微信公众平台获取：https://mp.weixin.qq.com

# 微信小程序 AppID（示例：wx1234567890abcdef）
WECHAT_APP_ID=

# 微信小程序 AppSecret（示例：1234567890abcdef1234567890abcdef）
WECHAT_APP_SECRET=

# ==================== JWT 认证配置 ====================
# JWT 密钥（生产环境请使用强随机字符串）
JWT_SECRET=ielts_vocab_dev_secret_2026_change_in_production

# Token 有效期（默认 7 天）
JWT_EXPIRES_IN=7d

# ==================== 管理员配置 ====================
# 首个管理员的微信 openid（登录一次后从后端日志中获取）
# 格式示例：ou_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ADMIN_OPENID=

# ==================== 服务器配置 ====================
PORT=3001
NODE_ENV=development

# ==================== 有道 TTS 配置 ====================
# 可选配置，用于单词发音和翻译
YOUDAO_APP_KEY=
YOUDAO_SECRET_KEY=

# ==================== 数据库配置 ====================
# SQLite 数据库文件路径（相对路径）
DB_PATH=./scripts/ielts_vocab.db

# ==================== SSL 证书配置 ====================
# HTTPS 证书路径（生产环境）
# SSL_CERT_PATH=/etc/letsencrypt/live/caiyuyang.cn/fullchain.pem
# SSL_KEY_PATH=/etc/letsencrypt/live/caiyuyang.cn/privkey.pem

# ==================== 系统功能开关 ====================
# 是否启用管理员后台
ENABLE_ADMIN_PANEL=true
# 是否启用用户学习进度复位
ENABLE_USER_RESET=true
